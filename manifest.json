{
  "manifest_version": 3,
  "name": "Wiki Skin Selector",
  "version": "0.1",
  "content_scripts": [
    {
      "matches": [
        "*://*.wikipedia.org/*",
        "*://*.wiktionary.org/*",
        "*://*.wikibooks.org/*",
        "*://*.wikinews.org/*",
        "*://*.wikiquote.org/*",
        "*://*.wikisource.org/*",
        "*://*.wikiversity.org/*",
        "*://*.wikivoyage.org/*",
        "*://*.wikimedia.org/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}